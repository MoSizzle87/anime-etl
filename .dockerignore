# ============================================================
# .gitignore - Projet ETL Anime & Manga Intelligence
# ============================================================

# --- Variables d'environnement (JAMAIS commiter) ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Tests & Coverage ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# --- Linting & Type checking ---
.mypy_cache/
.flake8

# --- Data (raw data = trop lourde, processed = générée) ---
data/raw/
data/processed/

# --- Bases de données locales ---
*.db
*.sqlite
*.sqlite3

# --- Logs ---
*.log
logs/

# --- Great Expectations (artefacts générés) ---
great_expectations/uncommitted/

# --- Docker ---
.docker/

# --- OS ---
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Jupyter (si utilisé pour exploration) ---
.ipynb_checkpoints/
*.ipynb
