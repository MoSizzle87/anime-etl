# ============================================================
# .dockerignore - Exclude from Docker build context
# ============================================================

# --- Git ---
.git/
.gitignore
.gitattributes

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# --- Data (too large for Docker image) ---
data/

# --- Tests ---
tests/
.pytest_cache/
.coverage
htmlcov/

# --- Documentation ---
README.md
docs/
*.md

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Environment files ---
.env
.env.*

# --- CI/CD ---
.github/

# --- Other ---
*.log
.DS_Store
